{
  "name": "@forjd/ctx",
  "version": "1.4.0",
  "private": false,
  "description": "Local context packs for coding agents.",
  "keywords": [
    "agents",
    "bun",
    "cli",
    "code-context",
    "context"
  ],
  "homepage": "https://github.com/forjd/ctx#readme",
  "bugs": {
    "url": "https://github.com/forjd/ctx/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forjd/ctx.git"
  },
  "bin": {
    "ctx": "src/cli/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "src/cli/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "ctx": "bun run src/cli/index.ts",
    "dev": "bun run src/cli/index.ts",
    "lint": "oxlint .",
    "format": "oxfmt --config .oxfmt.json --write .",
    "format:check": "oxfmt --config .oxfmt.json --check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "coverage": "bun run scripts/check-coverage.ts",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.3.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {},
  "engines": {
    "bun": ">=1.2.0"
  }
}
